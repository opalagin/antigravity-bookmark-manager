# Domain Configuration (local Docker Compose only)
DOMAIN_NAME=localhost
ACME_EMAIL=your-email@example.com

# Database Configuration — local Docker Compose
POSTGRES_USER=bookmark_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=bookmarks_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database Configuration — Railway (auto-injected by Railway Postgres plugin)
# If set, this takes precedence over the individual POSTGRES_* vars above.
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Backend Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Pilot Mode (optional — comma-separated emails to seed on first run)
# PILOT_MODE_EMAILS=alex.palagin@gmail.com

# JWT Configuration
# Generate a secret that is at least 32 bytes/characters long
JWT_SECRET=some_random_secret_at_least_32_bytes_long
# JWT_SECRET_PREVIOUS=
# JWT_ACCESS_TTL_SECONDS=1800
# JWT_REFRESH_TTL_SECONDS=7776000
# JWT_ISSUER=smart-bookmark-manager
# JWT_AUDIENCE=api

# Legacy google token migration support (set to 1 to allow old extension clients to function)
AUTH_ALLOW_LEGACY_GOOGLE_TOKEN=1

# Microsoft Edge Add-ons Store Configuration (for deploy_edge.ps1)
# EDGE_PRODUCT_ID=your-product-uuid-here
# EDGE_CLIENT_ID=your-client-id-here
# EDGE_API_KEY=your-api-key-here


