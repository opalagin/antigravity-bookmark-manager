{
    "manifest_version": 3,
    "name": "Smart Bookmark Manager",
    "version": "1.0.15",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "smart-bookmark-manager@antigravity.local",
            "data_collection_permissions": {
                "required": [
                    "none"
                ],
                "optional": []
            }
        }
    },
    "description": "AI-powered personal knowledge base for your bookmarks.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "identity"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Smart Bookmark Manager",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        }
    },
    "options_ui": {
        "page": "options.html"
    },
    "sidebar_action": {
        "default_panel": "sidebar.html",
        "default_title": "Smart Bookmarks",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        }
    },
    "host_permissions": [
        "http://localhost/*",
        "https://localhost/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    }
}